rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validator for Order
    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'passCode', 'customerName', 'items', 'total', 'status', 'createdAt'])
        && data.id is string && data.id.size() <= 128
        && data.passCode is string && data.passCode.size() <= 30
        && data.customerName is string && data.customerName.size() <= 100
        && data.items is list
        && data.total is number && data.total >= 0
        && data.status is string && (data.status == 'pending' || data.status == 'verified' || data.status == 'completed' || data.status == 'cancelled')
        && data.createdAt is number
        && (!data.keys().hasAll(['verifiedAt']) || data.verifiedAt is number)
        && (!data.keys().hasAll(['completedAt']) || data.completedAt is number);
    }

    // Entity validator for NfcBeacon
    function isValidNfcBeacon(data) {
      return data.keys().hasAll(['id', 'passCode', 'timestamp'])
        && data.id is string && data.id.size() <= 128
        && data.passCode is string && data.passCode.size() <= 30
        && data.timestamp is number;
    }

    // Rule: admin_config collection
    match /admin_config/{configId} {
      allow read: if true;
      allow write: if isValidId(configId) && configId == 'menu_status';
    }

    // Rule: orders collection
    match /orders/{orderId} {
      allow read: if true;
      allow create: if isValidId(orderId) && orderId == incoming().id && isValidOrder(incoming());
      allow update: if isValidId(orderId) && isValidOrder(incoming()) && incoming().createdAt == existing().createdAt && incoming().id == existing().id;
      allow delete: if isValidId(orderId);
    }

    // Rule: nfc_beacons collection
    match /nfc_beacons/{beaconId} {
      allow read: if true;
      allow create: if isValidId(beaconId) && beaconId == incoming().id && isValidNfcBeacon(incoming());
      allow delete: if isValidId(beaconId);
    }
  }
}
